<Window x:Class="OpenWithTool.Views.SitesSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sites settings"
        Height="520"
        Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Manage remembered sites and default browsers"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Rules}"
                  SelectedItem="{Binding SelectedRule}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Match" Binding="{Binding Pattern}" Width="*"/>
                <DataGridTextColumn Header="Browser" Binding="{Binding BrowserDisplayName}" Width="160"/>
                <DataGridTextColumn Header="Profile" Binding="{Binding ProfileName}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="2" Header="Add new site rule" Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="URL:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Column="1" Text="{Binding NewRuleUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,16,8"/>
                <TextBlock Grid.Column="2" Text="Match by:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding MatchTypes}" SelectedItem="{Binding NewRuleMatchType}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="Browser:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Browsers}" SelectedItem="{Binding NewRuleBrowser}" DisplayMemberPath="DisplayName" Margin="0,0,16,0"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Profile:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding NewRuleBrowser.Profiles}" SelectedItem="{Binding NewRuleProfile}" DisplayMemberPath="Name" Width="110" Margin="0,0,8,0"/>
                    <Button Content="Add" Command="{Binding AddCommand}" Width="42"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Remove" Command="{Binding RemoveCommand}" Width="80" Height="32" Margin="0,0,8,0"/>
            <Button Content="Close" Command="{Binding SaveCommand}" Width="80" Height="32" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
