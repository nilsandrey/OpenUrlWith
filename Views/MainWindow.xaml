<Window x:Class="OpenWithTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Open With..."
        Height="560"
        Width="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        FocusManager.FocusedElement="{Binding ElementName=BrowserListBox}"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <Window.Resources>
        <Style x:Key="BrowserItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F8FF"/>
                                <Setter Property="BorderBrush" Value="#4169E1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E6F3FF"/>
                                <Setter Property="BorderBrush" Value="#1E90FF"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProfileRadioListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,0,8,4"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Profiles.Count}" Value="0">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Profiles.Count}" Value="1">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProfileRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Select a browser to open the link:"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- URL Display -->
        <Border Grid.Row="1"
                Background="#F8F9FA"
                BorderBrush="#E9ECEF"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding Url}"
                       TextWrapping="Wrap"
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="#495057"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="1"
                      Content="Remember my selection for this site"
                      IsChecked="{Binding RememberSelection}"
                      VerticalAlignment="Center"
                      Margin="0,0,8,0"/>
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding MatchOptions}"
                      SelectedItem="{Binding SelectedMatchOption}"
                      DisplayMemberPath="DisplayText"
                      IsEnabled="{Binding RememberSelection}"/>
        </Grid>

        <!-- Timer Display -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsTimerActive}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="Auto-selecting in " FontSize="12" Foreground="#6C757D"/>
            <TextBlock Text="{Binding TimeRemaining}" FontSize="12" FontWeight="Bold" Foreground="#DC3545"/>
            <TextBlock Text=" seconds..." FontSize="12" Foreground="#6C757D"/>
        </StackPanel>

        <!-- Browser List -->
        <ListBox Grid.Row="4"
                 x:Name="BrowserListBox"
                 ItemsSource="{Binding Browsers}"
                 SelectedItem="{Binding SelectedBrowser}"
                 ItemContainerStyle="{StaticResource BrowserItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionMode="Single">
            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBrowserFocused}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Browser Icon -->
                        <Border Grid.Column="0"
                                Width="32"
                                Height="32"
                                Background="#F8F9FA"
                                BorderBrush="#DEE2E6"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,0,12,0">
                            <Image Source="{Binding IconPath}"
                                   Width="24"
                                   Height="24"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <!-- Browser Info -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding SelectedProfile.Name}"
                                       FontSize="12"
                                       Foreground="#6C757D">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Profile Selector -->
                        <ListBox Grid.Column="2"
                                 ItemsSource="{Binding Profiles}"
                                 SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 Style="{StaticResource ProfileRadioListBoxStyle}"
                                 VerticalAlignment="Center"
                                 Margin="8,0,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Content="{Binding Name}"
                                                 IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}"
                                                 Style="{StaticResource ProfileRadioButtonStyle}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Column="3"
                                Command="{Binding DataContext.FocusBrowserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                ToolTip="Focus on this browser"
                                Width="36"
                                Height="32"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Content="↪"
                                FontSize="18"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>



        <!-- Focused Browser Profile Picker -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="14">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBrowserFocused}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <DockPanel Margin="0,0,0,16">
                    <Button Content="Other browser"
                            Command="{Binding ShowOtherBrowsersCommand}"
                            DockPanel.Dock="Right"
                            Width="110"
                            Height="32"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Margin="0,0,12,0">
                            <Image Source="{Binding FocusedBrowser.IconPath}" Width="30" Height="30" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <TextBlock Text="{Binding FocusedBrowser.DisplayName}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>

                <TextBlock Text="Choose a profile:" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding FocusedBrowser.Profiles}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectFocusedProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Width="96"
                                    Height="118"
                                    Margin="0,0,12,0"
                                    Padding="8">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#DEE2E6"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#E6F3FF"/>
                                                <Setter Property="BorderBrush" Value="#1E90FF"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24" Background="#0D6EFD" Margin="0,0,0,8">
                                        <TextBlock Text="👤" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="ⓘ This focused view will be remembered for next time."
                           Foreground="#5A6F95"
                           FontSize="12"
                           Margin="0,14,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <TextBlock Grid.Row="5"
                   Text="{Binding StatusMessage}"
                   FontSize="11"
                   Foreground="#6C757D"
                   Margin="0,8,0,8"
                   TextTrimming="CharacterEllipsis"/>

        <!-- Buttons -->
        <DockPanel Grid.Row="6">
            <Button Content="Sites settings"
                    Command="{Binding SitesSettingsCommand}"
                    Width="100"
                    Height="32"
                    DockPanel.Dock="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    Width="80"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>

            <Button Content="Settings"
                    Command="{Binding SettingsCommand}"
                    Width="80"
                    Height="32"
                    Margin="0,0,8,0"
                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>

            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    Height="32"
                    Margin="0,0,8,0"
                    IsCancel="True"/>

            <Button Content="Open"
                    Command="{Binding LaunchCommand}"
                    Width="80"
                    Height="32"
                    IsDefault="True"
                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"
                    Background="#0D6EFD"
                    Foreground="White"
                    BorderBrush="#0D6EFD"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
